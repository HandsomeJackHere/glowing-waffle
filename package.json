{
  "name": "glowing-waffle-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "budget-tracker-initial"
  ],
  "scripts": {
    "start": "npm --workspace=budget-tracker-initial start",
    "install:all": "npm install --workspaces",
